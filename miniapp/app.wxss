page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 14px;
  color: #333;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 通用按钮 */
.btn-primary {
  background: #409eff;
  color: #fff;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: 16px;
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 12px;
}
.tag-success { background: #e1f3d8; color: #67c23a; }
.tag-warning { background: #fdf6ec; color: #e6a23c; }
.tag-info    { background: #ecf5ff; color: #409eff; }
.tag-danger  { background: #fef0f0; color: #f56c6c; }
.tag-default { background: #f4f4f5; color: #909399; }

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #c0c4cc;
  font-size: 15px;
}

/* 文本截断 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
