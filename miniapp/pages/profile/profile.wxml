<view class="container">
  <!-- 头像区域 -->
  <view class="card profile-header">
    <image class="avatar" src="/images/avatar.png" mode="aspectFill" />
    <text class="profile-name">{{userInfo ? userInfo.realName : '未登录'}}</text>
    <text class="profile-role">{{roleLabel}}</text>
  </view>

  <!-- 信息列表 -->
  <view class="card" wx:if="{{userInfo}}">
    <view class="info-row">
      <text class="info-label">用户名</text>
      <text class="info-val">{{userInfo.username}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.realName}}">
      <text class="info-label">姓名</text>
      <text class="info-val">{{detail.realName}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.phone}}">
      <text class="info-label">手机号</text>
      <text class="info-val">{{detail.phone}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.email}}">
      <text class="info-label">邮箱</text>
      <text class="info-val">{{detail.email || '未填写'}}</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="card" style="margin-top:32rpx" wx:if="{{token}}">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
