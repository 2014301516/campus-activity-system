.reg-item { margin-bottom: 16rpx; }
.reg-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.reg-title { flex: 1; font-size: 16px; font-weight: 600; margin-right: 16rpx; }
.reg-meta { font-size: 13px; color: #909399; margin-bottom: 12rpx; }
.reg-deleted { color: #c0c4cc; font-style: italic; }
.reg-actions { display: flex; gap: 16rpx; align-items: center; }
.status-text { font-size: 13px; color: #67c23a; }
.link { color: #409eff; }
